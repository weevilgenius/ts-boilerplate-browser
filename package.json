{
  "name": "ts-boilerplate-browser",
  "version": "0.2.0",
  "description": "Boilerplate for a Typescript project targeting the browser",
  "main": "index.js",
  "scripts": {
    "postinstall": "playwright install chromium",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "dev": "vite",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview",
    "analyze": "pnpm run typecheck && ANALYZE=1 vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshot": "node scripts/screenshot.ts",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
