{
  "name": "ts-boilerplate-browser",
  "version": "0.2.0",
  "description": "Boilerplate for a Typescript project targeting the browser",
  "main": "index.js",
  "scripts": {
    "postinstall": "playwright install chromium",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "dev": "vite",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview",
    "analyze": "pnpm run typecheck && ANALYZE=1 vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshot": "node scripts/screenshot.ts",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
